{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://therealjameswilson.github.io/g7-presidency-history/schemas/summits.schema.json",
  "title": "G7 Presidency History annual summit collection",
  "type": "object",
  "required": ["meta", "summits"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["title", "updated", "expected_records"],
      "properties": {
        "title": { "type": "string" },
        "updated": { "type": "string", "format": "date" },
        "expected_records": { "const": 52 }
      }
    },
    "summits": {
      "type": "array",
      "minItems": 52,
      "maxItems": 52,
      "items": { "$ref": "#/$defs/summit" }
    }
  },
  "$defs": {
    "summit": {
      "type": "object",
      "required": ["id", "year", "name", "summit_title", "format", "status", "host_country", "dates", "era", "summary", "themes", "outcomes", "documents", "record_status", "data_gaps"],
      "properties": {
        "id": { "type": "string", "pattern": "^[0-9]{4}-[a-z0-9-]+$" },
        "year": { "type": "integer", "minimum": 1975, "maximum": 2026 },
        "name": { "type": "string", "minLength": 2 },
        "summit_title": { "type": "string", "minLength": 2 },
        "format": { "enum": ["G6", "G7", "G8", "G7/G8 transition"] },
        "status": { "enum": ["held", "virtual", "replacement", "planned-not-held"] },
        "host_country": { "type": "string" },
        "dates": {
          "type": "object",
          "required": ["display"],
          "properties": {
            "display": { "type": "string" },
            "start": { "type": ["string", "null"] },
            "end": { "type": ["string", "null"] }
          }
        },
        "era": { "enum": ["Founding group", "Established G7", "Post-Cold War transition", "G8 period", "Renewed G7", "Crisis-era G7"] },
        "themes": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
        "outcomes": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "documents": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/document" } },
        "data_gaps": { "type": "array", "items": { "type": "string" } }
      }
    },
    "document": {
      "type": "object",
      "required": ["title", "url", "publisher", "tier", "type"],
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string", "pattern": "^https://" },
        "publisher": { "type": "string" },
        "tier": { "type": "integer", "minimum": 1, "maximum": 3 },
        "type": { "type": "string" }
      }
    }
  }
}
